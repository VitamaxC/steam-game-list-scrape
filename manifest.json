{
    "name": "Steam游戏清单爬取",
    "description": "以json格式爬取 https://steamcommunity.com/my/games 中加载的游戏清单",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "*://steamcommunity.com/*"
    ],
    "action": {
        "default_title": "Steam游戏清单爬取",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/16.png",
            "32": "icons/32.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "48": "icons/48.png",
        "128": "icons/128.png"
    }
}